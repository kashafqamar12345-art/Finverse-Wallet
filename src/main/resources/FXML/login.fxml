<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controllers.LoginController"
      prefWidth="900" prefHeight="600"
      style="-fx-background-color: #0D1117;">

    <!-- ── LEFT BRAND PANEL -->
    <VBox prefWidth="380" alignment="CENTER" spacing="16"
          style="-fx-background-color: linear-gradient(to bottom right, #0D1117, #161B22);
                 -fx-padding: 60px 50px;
                 -fx-border-color: transparent #21262D transparent transparent;
                 -fx-border-width: 0 1 0 0;">

        <!-- Logo -->
        <Label text="₹" style="-fx-font-size: 64px; -fx-text-fill: #00D4AA;
                               -fx-effect: dropshadow(gaussian, rgba(0,212,170,0.5), 20, 0, 0, 0);"/>

        <Label text="FinVerse Wallet"
               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #E6EDF3;"/>

        <Label text="Digital Wallet Transaction System"
               style="-fx-font-size: 13px; -fx-text-fill: #8B949E;"/>

        <Region prefHeight="30"/>

        <!-- Feature bullets -->
        <VBox spacing="14" alignment="CENTER_LEFT">
            <Label text="✦  Secure BCrypt authentication"
                   style="-fx-text-fill: #8B949E; -fx-font-size: 13px;"/>
            <Label text="✦  Atomic fund transfers"
                   style="-fx-text-fill: #8B949E; -fx-font-size: 13px;"/>
            <Label text="✦  Real-time transaction history"
                   style="-fx-text-fill: #8B949E; -fx-font-size: 13px;"/>
            <Label text="✦  Multi-wallet support"
                   style="-fx-text-fill: #8B949E; -fx-font-size: 13px;"/>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <Label text="DBMS Semester Project"
               style="-fx-text-fill: #30363D; -fx-font-size: 11px;"/>
    </VBox>

    <!-- ── RIGHT LOGIN FORM -->
    <VBox HBox.hgrow="ALWAYS" alignment="CENTER"
          style="-fx-background-color: #0D1117; -fx-padding: 60px 70px;">

        <VBox maxWidth="340" spacing="0">

            <Label text="Welcome Back"
                   style="-fx-font-size: 26px; -fx-font-weight: bold;
                          -fx-text-fill: #E6EDF3;"/>
            <Label text="Sign in to your account"
                   style="-fx-font-size: 13px; -fx-text-fill: #8B949E;
                          -fx-padding: 4 0 28 0;"/>

            <!-- Username -->
            <Label text="Username"
                   style="-fx-text-fill: #8B949E; -fx-font-size: 12px;
                          -fx-font-weight: bold; -fx-padding: 0 0 6 0;"/>
            <TextField fx:id="usernameField"
                       promptText="Enter your username"
                       styleClass="text-field"
                       prefWidth="340" prefHeight="44"/>

            <Region prefHeight="16"/>

            <!-- Password -->
            <Label text="Password"
                   style="-fx-text-fill: #8B949E; -fx-font-size: 12px;
                          -fx-font-weight: bold; -fx-padding: 0 0 6 0;"/>
            <PasswordField fx:id="passwordField"
                           promptText="Enter your password"
                           styleClass="password-field"
                           prefWidth="340" prefHeight="44"/>

            <Region prefHeight="8"/>

            <!-- Error -->
            <Label fx:id="errorLabel" text=""
                   style="-fx-text-fill: #FF6B6B; -fx-font-size: 12px;
                          -fx-padding: 4 0 8 0;"/>

            <Region prefHeight="8"/>

            <!-- Login Button -->
            <Button text="Sign In →" onAction="#handleLogin"
                    styleClass="btn-primary"
                    prefWidth="340" prefHeight="46"/>

            <Region prefHeight="20"/>

            <!-- Divider -->
            <HBox alignment="CENTER" spacing="12">
                <Region HBox.hgrow="ALWAYS"
                        style="-fx-background-color: #30363D; -fx-pref-height: 1;"/>
                <Label text="or"
                       style="-fx-text-fill: #8B949E; -fx-font-size: 12px;"/>
                <Region HBox.hgrow="ALWAYS"
                        style="-fx-background-color: #30363D; -fx-pref-height: 1;"/>
            </HBox>

            <Region prefHeight="20"/>

            <!-- Register Link -->
            <HBox alignment="CENTER" spacing="6">
                <Label text="Don't have an account?"
                       style="-fx-text-fill: #8B949E; -fx-font-size: 13px;"/>
                <Button text="Create Account" onAction="#goToRegister"
                        styleClass="btn-link"/>
            </HBox>

        </VBox>
    </VBox>
</HBox>
