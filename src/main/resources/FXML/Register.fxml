<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controllers.RegisterController"
      prefWidth="900" prefHeight="600"
      style="-fx-background-color: #0D1117;">

    <!-- ── LEFT BRAND PANEL -->
    <VBox prefWidth="380" alignment="CENTER" spacing="16"
          style="-fx-background-color: linear-gradient(to bottom right, #0D1117, #161B22);
                 -fx-padding: 60px 50px;
                 -fx-border-color: transparent #21262D transparent transparent;
                 -fx-border-width: 0 1 0 0;">

        <Label text="₣"
               style="-fx-font-size: 64px; -fx-text-fill: #00D4AA;
                      -fx-effect: dropshadow(gaussian, rgba(0,212,170,0.5), 20, 0, 0, 0);"/>
        <Label text="FinVerse Wallet"
               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #E6EDF3;"/>
        <Label text="Create your free account today"
               style="-fx-font-size: 13px; -fx-text-fill: #8B949E;"/>

        <Region prefHeight="30"/>

        <VBox spacing="18" alignment="CENTER_LEFT"
              style="-fx-background-color: #161B22; -fx-background-radius: 12;
                     -fx-border-color: #30363D; -fx-border-radius: 12;
                     -fx-border-width: 1; -fx-padding: 24 20;">
            <Label text="🔒  Passwords are hashed with BCrypt"
                   style="-fx-text-fill: #8B949E; -fx-font-size: 12px;"/>
            <Label text="🏦  Wallet auto-created on signup"
                   style="-fx-text-fill: #8B949E; -fx-font-size: 12px;"/>
            <Label text="⚡  Instant transfers between users"
                   style="-fx-text-fill: #8B949E; -fx-font-size: 12px;"/>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>
        <Label text="DBMS Semester Project"
               style="-fx-text-fill: #30363D; -fx-font-size: 11px;"/>
    </VBox>

    <!-- ── RIGHT REGISTER FORM -->
    <VBox HBox.hgrow="ALWAYS" alignment="CENTER"
          style="-fx-background-color: #0D1117; -fx-padding: 50px 70px;">

        <VBox maxWidth="340" spacing="0">

            <Label text="Create Account"
                   style="-fx-font-size: 26px; -fx-font-weight: bold;
                          -fx-text-fill: #E6EDF3;"/>
            <Label text="Join FinVerse in seconds"
                   style="-fx-font-size: 13px; -fx-text-fill: #8B949E;
                          -fx-padding: 4 0 24 0;"/>

            <!-- Username -->
            <Label text="USERNAME"
                   style="-fx-text-fill: #8B949E; -fx-font-size: 11px;
                          -fx-font-weight: bold; -fx-padding: 0 0 6 0;"/>
            <TextField fx:id="usernameField"
                       promptText="Choose a username (min 3 chars)"
                       styleClass="text-field"
                       prefWidth="340" prefHeight="44"/>

            <Region prefHeight="14"/>

            <!-- Email -->
            <Label text="EMAIL ADDRESS"
                   style="-fx-text-fill: #8B949E; -fx-font-size: 11px;
                          -fx-font-weight: bold; -fx-padding: 0 0 6 0;"/>
            <TextField fx:id="emailField"
                       promptText="your@email.com"
                       styleClass="text-field"
                       prefWidth="340" prefHeight="44"/>

            <Region prefHeight="14"/>

            <!-- Password -->
            <Label text="PASSWORD"
                   style="-fx-text-fill: #8B949E; -fx-font-size: 11px;
                          -fx-font-weight: bold; -fx-padding: 0 0 6 0;"/>
            <PasswordField fx:id="passwordField"
                           promptText="Min 6 characters"
                           styleClass="password-field"
                           prefWidth="340" prefHeight="44"/>

            <Region prefHeight="14"/>

            <!-- Confirm Password -->
            <Label text="CONFIRM PASSWORD"
                   style="-fx-text-fill: #8B949E; -fx-font-size: 11px;
                          -fx-font-weight: bold; -fx-padding: 0 0 6 0;"/>
            <PasswordField fx:id="confirmPasswordField"
                           promptText="Re-enter password"
                           styleClass="password-field"
                           prefWidth="340" prefHeight="44"/>

            <Region prefHeight="10"/>

            <!-- Message Label -->
            <Label fx:id="messageLabel" text=""
                   wrapText="true" maxWidth="340"
                   style="-fx-font-size: 12px; -fx-padding: 4 0 8 0;"/>

            <Region prefHeight="8"/>

            <!-- Register Button -->
            <Button fx:id="registerButton"
                    text="Create My Account →"
                    onAction="#handleRegister"
                    styleClass="btn-primary"
                    prefWidth="340" prefHeight="46"/>

            <Region prefHeight="20"/>

            <!-- Back to login -->
            <HBox alignment="CENTER" spacing="6">
                <Label text="Already have an account?"
                       style="-fx-text-fill: #8B949E; -fx-font-size: 13px;"/>
                <Button text="Sign In" onAction="#goToLogin"
                        styleClass="btn-link"/>
            </HBox>

        </VBox>
    </VBox>
</HBox>
